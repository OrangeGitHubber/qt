{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "qt",
      "runtimeExecutable": ".venv/Scripts/python",
      "runtimeArgs": ["-m", "uvicorn", "qt.main:app", "--port", "8420"],
      "port": 8420,
      "env": {
        "QT_AUTH_DISABLED": "true",
        "QT_NO_SCHEDULER": "true"
      }
    },
    {
      "name": "qt-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5173"],
      "cwd": "frontend",
      "port": 5173
    }
  ]
}
